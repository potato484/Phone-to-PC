PORT=3000
# tailscale only
TUNNEL=tailscale
# true = tailscale funnel (public), false = tailscale serve (tailnet only)
TAILSCALE_FUNNEL=false
# Optional: override tailscale binary path (default: tailscale)
# C2P_TAILSCALE_BIN=/usr/bin/tailscale
# Optional: override sqlite path (default: ./.c2p-store.sqlite)
# C2P_DB_PATH=/path/to/.c2p-store.sqlite
# Optional: override tmux binary path (default: tmux)
# C2P_TMUX_BIN=/usr/bin/tmux
# Optional: access token TTL in seconds (default 86400)
# C2P_ACCESS_TOKEN_TTL_SECONDS=86400
# Optional: audit log directory and retention days
# C2P_AUDIT_DIR=.c2p-audit
# C2P_AUDIT_RETENTION_DAYS=90
# Optional: default client feature flags (comma list or JSON array)
# Example: localEcho
# C2P_DEFAULT_FLAGS=
# Optional: security policy allowlists
# C2P_ALLOWED_ORIGINS=https://example.com,https://foo.example.com
# C2P_ALLOWED_HOSTS=example.com,localhost,127.0.0.1
# C2P_ALLOW_EMPTY_ORIGIN=true
